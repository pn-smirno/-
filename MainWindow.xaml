<Window x:Class="WarehouseApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WarehouseApp.ViewModels"
        xmlns:converters="clr-namespace:WarehouseApp.Converters"
        mc:Ignorable="d"
        Title="Складской учёт" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <converters:TypeToColorConverter x:Key="TypeToColorConverter"/>
    </Window.Resources>
    <Window.DataContext>
        <local:MainViewModel/>
    </Window.DataContext>

    <!-- Корневой Grid с двумя колонками 1:3 -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <!-- 25% -->
            <ColumnDefinition Width="3*"/>
            <!-- 75% -->
        </Grid.ColumnDefinitions>

		<!--  Категории (25%) -->
		<Grid Grid.Column="0" Background="#F0F0F0" Margin="5">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<TextBlock Text="Категории" FontWeight="Bold" FontSize="16" Margin="5" TextAlignment="Center"/>

		
			<Button Grid.Row="1" Content=" Добавить категорию" Command="{Binding AddCategoryCommand}"
					Margin="5" Padding="5" Background="LightBlue"/>

			
			<ListBox Grid.Row="2" ItemsSource="{Binding Categories}"
					 SelectedItem="{Binding SelectedCategory}" Margin="5">
				<ListBox.ItemTemplate>
					<DataTemplate>
						<TextBlock Text="{Binding Name}" FontSize="14" Margin="3"/>
					</DataTemplate>
				</ListBox.ItemTemplate>
			</ListBox>
		</Grid>

        <!--  Основная информация (75%) -->
        <Grid Grid.Column="1" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <TextBlock Text="Товары в выбранной категории" FontWeight="Bold" FontSize="16" Margin="5"/>

            <!-- Список товаров -->
            <ListView Grid.Row="1" ItemsSource="{Binding Products}" 
                      SelectedItem="{Binding SelectedProduct}" Margin="5">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="ID" Width="50" DisplayMemberBinding="{Binding Id}"/>
                        <GridViewColumn Header="Название" Width="200" DisplayMemberBinding="{Binding Name}"/>
                        <GridViewColumn Header="SKU" Width="120" DisplayMemberBinding="{Binding SKU}"/>
                        <GridViewColumn Header="Остаток" Width="80" DisplayMemberBinding="{Binding Quantity}"/>
                    </GridView>
                </ListView.View>
            </ListView>

            <!-- Кнопки управления товарами -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="5">
                <Button Content=" Добавить товар" Command="{Binding AddProductCommand}" 
                        Width="150" Margin="5" Padding="5"/>
                <Button Content=" Удалить товар" Command="{Binding DeleteProductCommand}" 
                        Width="150" Margin="5" Padding="5" Background="LightCoral"/>
            </StackPanel>

            <!-- Панель операций с выбранным товаром -->
            <Border Grid.Row="3" BorderBrush="Gray" BorderThickness="1" Margin="5" Padding="10">
                <StackPanel>
                    <TextBlock Text="Операции с выбранным товаром" FontWeight="Bold" FontSize="14"/>

                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Количество:" Grid.Row="0" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding MovementQuantity, UpdateSourceTrigger=PropertyChanged}" 
                                 Grid.Row="0" Grid.Column="1" Margin="5" Width="150" HorizontalAlignment="Left"/>

                        <TextBlock Text="Комментарий:" Grid.Row="1" Grid.Column="0" Margin="5" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding MovementComment}" Grid.Row="1" Grid.Column="1" Margin="5" Width="300" HorizontalAlignment="Left"/>

                        <Button Content=" Выполнить операцию" Command="{Binding AddMovementCommand}" 
                                Grid.Row="2" Grid.ColumnSpan="2" Width="200" Margin="5" Padding="5" 
                                HorizontalAlignment="Left" Background="LightGreen"/>
                    </Grid>

                    <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" Margin="5" FontSize="12"/>
                </StackPanel>
            </Border>

            <!-- История операций -->
            <Grid Grid.Row="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="История движений" FontWeight="Bold" FontSize="14" Margin="5"/>

                <ListView Grid.Row="1" ItemsSource="{Binding Movements}" Margin="5">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Дата" Width="120" DisplayMemberBinding="{Binding Date}"/>
                            <GridViewColumn Header="Тип" Width="80">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Type}" 
                                                   Foreground="{Binding Type, Converter={StaticResource TypeToColorConverter}}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Кол-во" Width="80" DisplayMemberBinding="{Binding Quantity}"/>
                            <GridViewColumn Header="Комментарий" Width="250" DisplayMemberBinding="{Binding Comment}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Grid>
    </Grid>
</Window>
